{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "Serve site (no install)",
      "type": "shell",
      "command": "python",
      "args": [
        "-m",
        "http.server",
        "5500"
      ],
      "isBackground": true,
      "group": "build",
      "problemMatcher": []
    },
    {
      "label": "Serve site (Node no install)",
      "type": "shell",
      "command": "npx",
      "args": [
        "--yes",
        "http-server",
        ".",
        "-p",
        "5500",
        "-c-1"
      ],
      "isBackground": true,
      "group": "build",
      "problemMatcher": []
    },
    {
      "label": "Run backend API",
      "type": "shell",
      "command": "npm",
      "args": [
        "start"
      ],
      "options": {
        "cwd": "${workspaceFolder}/BACKEND"
      },
      "isBackground": false,
      "group": "build",
      "problemMatcher": []
    }
  ]
}
